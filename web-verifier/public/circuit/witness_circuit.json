{"noir_version":"1.0.0-beta.20+b4236c1957d0c26cb65d82adc9e5447b6ff1d629","hash":"14710589887935200578","abi":{"parameters":[{"name":"secret_image_hash","type":{"kind":"field"},"visibility":"private"},{"name":"secret_latitude","type":{"kind":"field"},"visibility":"private"},{"name":"secret_longitude","type":{"kind":"field"},"visibility":"private"},{"name":"public_image_hash","type":{"kind":"field"},"visibility":"public"},{"name":"min_lat","type":{"kind":"field"},"visibility":"public"},{"name":"max_lat","type":{"kind":"field"},"visibility":"public"},{"name":"min_long","type":{"kind":"field"},"visibility":"public"},{"name":"max_long","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"fn main(\n    // PRIVATE INPUTS (The Witness)\n    secret_image_hash: Field, \n    secret_latitude: Field,\n    secret_longitude: Field,\n\n    // PUBLIC INPUTS\n    public_image_hash: pub Field,\n    min_lat: pub Field,\n    max_lat: pub Field,\n    min_long: pub Field,\n    max_long: pub Field\n) {\n    // 1. RULE: The hidden image hash MUST match the public image hash\n    // (In a real project, you'd prove the blurred image's relationship here)\n    assert(secret_image_hash == public_image_hash);\n\n    // 2. RULE: The location MUST be within the allowed boundaries\n    assert(secret_latitude as u32 > min_lat as u32);\n    assert(secret_latitude as u32 < max_lat as u32);\n    assert(secret_longitude as u32 > min_long as u32);\n    assert(secret_longitude as u32 < max_long as u32);\n}","path":"/home/ankita/witness_circuit/src/main.nr","function_locations":[{"start":288,"name":"main"}]}}}